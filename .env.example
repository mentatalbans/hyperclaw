# HyperClaw Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# ─── Anthropic (Required) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Supabase (Required for HyperMemory) ─────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# ─── Database (Required for HyperMemory) ─────────────────────────────────────
# Supabase connection string (use Transaction Pooler for serverless):
# Format: postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ─── Redis (auto-set in docker-compose) ──────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Optional APIs ───────────────────────────────────────────────────────────
# ChatJimmy (ultra-fast routing, 17K tok/sec): https://chatjimmy.ai
CHATJIMMY_API_KEY=

# RunwayML (video generation via COSMOS agent): https://runwayml.com
RUNWAY_API_KEY=

# ─── Server Config ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
