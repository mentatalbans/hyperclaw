# HyperClaw Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════════════

# Anthropic API Key (powers the AI)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Required for memory/persistence)
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase (recommended) or self-hosted PostgreSQL with pgvector
# Supabase: https://supabase.com → Create Project → Settings → Database
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Supabase keys (optional, for real-time features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ═══════════════════════════════════════════════════════════════════════════════
# MESSAGING INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram
# Create a bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Slack
# Create app: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Discord
# Create app: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# WhatsApp Business
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Microsoft Teams
# Setup: https://portal.azure.com → App registrations
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# SMS/Voice (Twilio)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE WORKSPACE
# ═══════════════════════════════════════════════════════════════════════════════

# OAuth credentials for Gmail, Calendar, Drive, Docs, etc.
# Create: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# MICROSOFT 365
# ═══════════════════════════════════════════════════════════════════════════════

# OAuth credentials for Outlook, OneDrive, SharePoint, etc.
# Create: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTIVITY
# ═══════════════════════════════════════════════════════════════════════════════

# Notion
# Create integration: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Airtable
# Get from: https://airtable.com/account
AIRTABLE_API_KEY=

# Linear
# Get from: https://linear.app/settings/api
LINEAR_API_KEY=

# Todoist
# Get from: https://todoist.com/prefs/integrations
TODOIST_API_TOKEN=

# Trello
# Get from: https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# Asana
# Get from: https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# CRM & SALES
# ═══════════════════════════════════════════════════════════════════════════════

# Salesforce
# Create Connected App: Setup → App Manager → New Connected App
SALESFORCE_CONSUMER_KEY=
SALESFORCE_CONSUMER_SECRET=
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# HubSpot
# Get from: Settings → Integrations → API Key
HUBSPOT_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPER TOOLS
# ═══════════════════════════════════════════════════════════════════════════════

# GitHub
# Create token: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitLab
# Create token: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=

# Jira / Confluence
# Create token: https://id.atlassian.com/manage/api-tokens
JIRA_URL=https://yourteam.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# FINANCE
# ═══════════════════════════════════════════════════════════════════════════════

# Stripe
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=

# QuickBooks
# Create app: https://developer.intuit.com/app/developer/dashboard
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL FEATURES
# ═══════════════════════════════════════════════════════════════════════════════

# ChatJimmy (ultra-fast routing, 17K tok/sec)
# Get from: https://chatjimmy.ai
CHATJIMMY_API_KEY=

# RunwayML (video generation)
# Get from: https://runwayml.com
RUNWAY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIG
# ═══════════════════════════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000
