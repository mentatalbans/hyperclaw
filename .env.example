# HyperClaw Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ═══════════════════════════════════════════════════════════════════════════════
# AI/LLM PROVIDERS — Choose your preferred AI backend
# ═══════════════════════════════════════════════════════════════════════════════

# Provider selection (anthropic, openai, gemini, mistral, groq, etc.)
HYPERCLAW_LLM_PROVIDER=anthropic

# Anthropic (Claude) — Primary provider
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-4o, o1, etc.)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Mistral AI
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Groq (Ultra-fast inference)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# xAI (Grok)
# Get from: https://console.x.ai
XAI_API_KEY=

# Amazon Bedrock
# Get from: AWS IAM Console
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# OpenRouter (Multi-model gateway)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Together AI
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Perplexity (Search-augmented AI)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# DeepSeek
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Qwen (Alibaba)
# Get from: https://dashscope.aliyun.com
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# Cerebras (Fast inference)
# Get from: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Hugging Face
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HF_TOKEN=

# Local inference
OLLAMA_HOST=http://localhost:11434
VLLM_HOST=http://localhost:8000/v1
LITELLM_HOST=http://localhost:4000/v1
LITELLM_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# EMBEDDINGS
# ═══════════════════════════════════════════════════════════════════════════════

HYPERCLAW_EMBEDDING_PROVIDER=openai

# Voyage AI
# Get from: https://dash.voyageai.com
VOYAGE_API_KEY=

# Cohere
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Jina
# Get from: https://jina.ai
JINA_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# VOICE/AUDIO
# ═══════════════════════════════════════════════════════════════════════════════

HYPERCLAW_STT_PROVIDER=whisper
HYPERCLAW_TTS_PROVIDER=elevenlabs

# ElevenLabs (Premium TTS)
# Get from: https://elevenlabs.io/api
ELEVENLABS_API_KEY=

# Deepgram (STT)
# Get from: https://console.deepgram.com
DEEPGRAM_API_KEY=

# AssemblyAI
# Get from: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# IMAGE/VIDEO GENERATION
# ═══════════════════════════════════════════════════════════════════════════════

HYPERCLAW_IMAGE_PROVIDER=dalle

# Stability AI (Stable Diffusion)
# Get from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Midjourney (requires proxy service)
MIDJOURNEY_API_KEY=
MIDJOURNEY_API_URL=

# Replicate
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# RunwayML (Video generation)
# Get from: https://runwayml.com
RUNWAY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SEARCH
# ═══════════════════════════════════════════════════════════════════════════════

HYPERCLAW_SEARCH_PROVIDER=duckduckgo

# SerpAPI (Google Search wrapper)
# Get from: https://serpapi.com/dashboard
SERPAPI_API_KEY=

# Bing Search
# Get from: https://portal.azure.com → Cognitive Services
BING_API_KEY=

# Tavily (AI-optimized search)
# Get from: https://tavily.com
TAVILY_API_KEY=

# Brave Search
# Get from: https://brave.com/search/api
BRAVE_API_KEY=

# You.com
# Get from: https://you.com/api
YOU_API_KEY=

# Google Custom Search
GOOGLE_CSE_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase (recommended) or self-hosted PostgreSQL with pgvector
# Supabase: https://supabase.com → Create Project → Settings → Database
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# MESSAGING INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram
# Create a bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Slack
# Create app: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Discord
# Create app: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# WhatsApp Business
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Microsoft Teams
# Setup: https://portal.azure.com → App registrations
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# SMS/Voice (Twilio)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Chat
GOOGLE_CHAT_WEBHOOK=
GOOGLE_CHAT_TOKEN=

# Signal (via signal-cli-rest-api)
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=

# Matrix
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=

# iMessage (via BlueBubbles)
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

# LINE
LINE_CHANNEL_ACCESS_TOKEN=

# WeChat
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Mattermost
MATTERMOST_URL=
MATTERMOST_TOKEN=

# IRC
IRC_SERVER=
IRC_PORT=6667
IRC_NICKNAME=HyperClaw
IRC_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# SOCIAL MEDIA
# ═══════════════════════════════════════════════════════════════════════════════

# Twitter/X
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=

# Instagram (requires Facebook Business)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Facebook
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# YouTube
YOUTUBE_API_KEY=
YOUTUBE_ACCESS_TOKEN=

# Bluesky
BLUESKY_HANDLE=
BLUESKY_PASSWORD=

# Mastodon
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# TikTok
TIKTOK_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# SMART HOME / IoT
# ═══════════════════════════════════════════════════════════════════════════════

# Philips Hue
HUE_BRIDGE_IP=
HUE_USERNAME=

# Home Assistant
HOMEASSISTANT_URL=http://localhost:8123
HOMEASSISTANT_TOKEN=

# Sonos
SONOS_API_KEY=
SONOS_HOUSEHOLD_ID=

# Spotify
SPOTIFY_ACCESS_TOKEN=

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Samsung SmartThings
SMARTTHINGS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE WORKSPACE
# ═══════════════════════════════════════════════════════════════════════════════

# OAuth credentials for Gmail, Calendar, Drive, Docs, Sheets, etc.
# Create: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CREDENTIALS_PATH=
GOOGLE_SHEETS_TOKEN=
GOOGLE_DOCS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# MICROSOFT 365
# ═══════════════════════════════════════════════════════════════════════════════

# OAuth credentials for Outlook, OneDrive, SharePoint, OneNote, etc.
# Create: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTIVITY
# ═══════════════════════════════════════════════════════════════════════════════

# Notion
# Create integration: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Airtable
# Get from: https://airtable.com/account
AIRTABLE_API_KEY=

# Linear
# Get from: https://linear.app/settings/api
LINEAR_API_KEY=

# Todoist
# Get from: https://todoist.com/prefs/integrations
TODOIST_API_TOKEN=

# Trello
# Get from: https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# Asana
# Get from: https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=

# ClickUp
# Get from: https://clickup.com/api
CLICKUP_API_KEY=

# Monday.com
# Get from: https://developer.monday.com
MONDAY_API_KEY=

# Obsidian (local vault path)
OBSIDIAN_VAULT=~/Documents/Obsidian

# Evernote
EVERNOTE_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# CRM & SALES
# ═══════════════════════════════════════════════════════════════════════════════

# Salesforce
# Create Connected App: Setup → App Manager → New Connected App
SALESFORCE_CONSUMER_KEY=
SALESFORCE_CONSUMER_SECRET=
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# HubSpot
# Get from: Settings → Integrations → API Key
HUBSPOT_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPER TOOLS
# ═══════════════════════════════════════════════════════════════════════════════

# GitHub
# Create token: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitLab
# Create token: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=

# Jira / Confluence
# Create token: https://id.atlassian.com/manage/api-tokens
JIRA_URL=https://yourteam.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE / CLOUD
# ═══════════════════════════════════════════════════════════════════════════════

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# Google Cloud Platform
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Microsoft Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Tailscale
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=-

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=

# PagerDuty
PAGERDUTY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# FINANCE
# ═══════════════════════════════════════════════════════════════════════════════

# Stripe
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=

# QuickBooks
# Create app: https://developer.intuit.com/app/developer/dashboard
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# Square
SQUARE_ACCESS_TOKEN=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL FEATURES
# ═══════════════════════════════════════════════════════════════════════════════

# ChatJimmy (ultra-fast routing, 17K tok/sec)
# Get from: https://chatjimmy.ai
CHATJIMMY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIG
# ═══════════════════════════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000
