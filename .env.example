# HyperClaw Environment Variables
# Copy to .env and fill in your values

# Required: Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Required for HyperMemory: PostgreSQL connection string
# Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Local:    postgresql://localhost/hyperclaw
DATABASE_URL=postgresql://...

# Optional: ChatJimmy API key (Taalas HC1 — 17K tok/sec, ultra-cheap routing)
# Get from: chatjimmy.ai
CHATJIMMY_API_KEY=

# Optional: RunwayML API key (for video generation via COSMOS agent)
RUNWAY_API_KEY=
